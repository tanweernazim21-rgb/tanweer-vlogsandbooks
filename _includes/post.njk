---
layout: layout.njk
---
<article class="article">
<p class="post-meta">{{ date | readableDate }}</p>
<h1>{{ title }}</h1>
{% if description %}<p class="section-sub" style="text-align:left;margin-left:0">{{ description }}</p>{% endif %}
{% if cover %}<img src="{{ cover }}" alt="{{ title }}" style="width:100%;border-radius:22px;margin:25px 0">{% endif %}
<div class="article-body">{{ content | safe }}</div>
<p><a class="btn" href="/blog/">Back to Blog</a></p>
</article>